#define ch 70                           
#define peak_n 1

int timing()                                                                                                                                            
{                                                                                                                                                         
  TSpectrum *s[peak_n];
  TFile *F[ch];
  TTree *T[ch];
  TH1F *h[ch];                                                                   
  TF1 *f[ch][peak_n];                                                          
  double *xpeaks[ch];                                                              
  double peak[peak_n];                                                                        
  double mean[ch][peak_n];                                                                        
  double sigma[ch][peak_n];                                                                       
  int n;                                                                                                                                                            
  ofstream ofs("log.txt",std::ios::app);                                 
                                                                     
  for(Int_t i=0;i<ch;i++){

    F[i] = new TFile(Form("../hit%d.root",2300+i));
    T[i] = (TTree*)F[i]->Get("hit"); 
    
    
    s[i] = new TSpectrum(peak_n);                                                                                                            
    h[i] = new TH1F(Form("h_%d",i),Form("h_%d",i),200,-50e3,50e3);
                                       
    T[i]->Draw(Form("ts_diff_f[0]>>h_%d",i),"","",1e5,0);  
    s[i]->Search(h[i],1,"new",0.1);                                                                                                                       
    xpeaks[i]=s[i]->GetPositionX();                                                                                                                       
                                                                                                                                                          
    for(Int_t j=0;j<peak_n;j++){                                                                                                                              
      peak[j]=xpeaks[i][j];                                                                                                                               
    }                                                                                                                                                     
    n = sizeof(peak)/sizeof(peak[0]);                                                                                                                     
    std::sort(peak,peak+n);                                                                                                                               
                                                                                                                                                          
    for(Int_t j=0;j<peak_n;j++){                                                                                                                          
      ofs << i << " " << j << " " << peak[j]/1e3 << " " << endl;                                                                            
    }                                                                                                                                                     

    h[i]->Draw();
  }                                                                                                                                                       
                                                                                                                                                          
  ofs.close();                                                                                                                                            
                                                                                                                                                          
  return 0;                                                                                                                                               
}                                                                                                                                                         
                       
